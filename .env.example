# X (Twitter) API 認証情報
# developer.twitter.com で取得
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_secret_here

# 投稿制御
# true にすると実際に X に投稿する（本番運用時のみ true に）
POST_ENABLED=false

# 収益化
# true にすると site/ に収益リンクを表示する
MONETIZATION_ENABLED=false

# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# スコア閾値（この値未満は投稿対象から除外）
MIN_SCORE=0.5

# 1回の実行で投稿する最大件数（レートリミット対策）
MAX_POSTS_PER_RUN=3
